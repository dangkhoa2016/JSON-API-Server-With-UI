{
  "name": "json-api-server-with-dashboard-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && esbuild api/boot.ts --platform=node --bundle --format=esm --outdir=dist --external:@node-rs/argon2 --banner:js=\"import { createRequire } from 'module';const require = createRequire(import.meta.url);\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "NODE_ENV=production node dist/boot.js",
    "check": "vue-tsc -b",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx db/seed.ts",
    "db:seed:settings": "tsx db/seed-settings.ts",
    "db:seed:admin": "tsx db/seed-admin.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@libsql/client": "^0.17.4",
    "@lucide/vue": "^1.14.0",
    "@node-rs/argon2": "^2.0.2",
    "@tanstack/vue-query": "^5.101.0",
    "@trpc-vue-query/client": "^0.1.0",
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "ioredis": "^5.11.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-sonner": "^2.0.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@hono/vite-dev-server": "^0.26.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.2.0"
  }
}
